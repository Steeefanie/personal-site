---
import { localeDateFormats, locales, type Localized } from '../lib/i18n';

interface Tag { id: string; label: string }
interface LocalizedPost {
  title: string;
  description: string;
  publishDate: Date;
  tags: Tag[];
  readingTime: string;
  attribution?: string;
}

interface Props {
  slug: string;
  locales: Localized<LocalizedPost>;
}

const { slug, locales: entries } = Astro.props;
const formatDate = (locale: keyof typeof entries, date: Date) => new Intl.DateTimeFormat(
  localeDateFormats[locale],
  { year: 'numeric', month: locale === 'en' ? 'short' : 'long', day: 'numeric' },
).format(date);
---

<li class="content-list-item">
  <a href={`/blog/${slug}/`}>
    <div>
      <h2 class="item-title">{locales.map((locale) => <span data-lang={locale}>{entries[locale].title}</span>)}</h2>
      <p class="item-description">{locales.map((locale) => <span data-lang={locale}>{entries[locale].attribution && <span class="content-attribution">{entries[locale].attribution}</span>}{entries[locale].description}</span>)}</p>
    </div>
    <div class="item-meta">
      <time datetime={entries['zh-CN'].publishDate.toISOString()}>{locales.map((locale) => <span data-lang={locale}>{formatDate(locale, entries[locale].publishDate)}</span>)}</time>
      {locales.map((locale) => <span data-lang={locale}>{entries[locale].readingTime}</span>)}
      <span class="tag-list">{locales.map((locale) => <span data-lang={locale}>{entries[locale].tags.map((tag) => <span class="tag">#{tag.label}</span>)}</span>)}</span>
    </div>
  </a>
</li>
