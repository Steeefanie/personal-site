---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LatestListItem from '../components/LatestListItem.astro';
import LocalizedText from '../components/LocalizedText.astro';
import { pairEntries } from '../lib/content';
import { locales, ui } from '../lib/i18n';

const [blogEntries, projectEntries, recipeEntries] = await Promise.all([
  getCollection('blog', ({ data }) => !data.draft),
  getCollection('projects', ({ data }) => !data.draft),
  getCollection('recipes', ({ data }) => !data.draft),
]);
const latest = [
  { section: 'blog' as const, group: pairEntries(blogEntries)[0], base: '/blog/' },
  { section: 'projects' as const, group: pairEntries(projectEntries)[0], base: '/projects/' },
  { section: 'recipes' as const, group: pairEntries(recipeEntries)[0], base: '/recipes/' },
].filter((item) => item.group).sort((a, b) => (
  b.group.locales['zh-CN'].data.publishDate.getTime() - a.group.locales['zh-CN'].data.publishDate.getTime()
));
---

<BaseLayout activeNav="home" titles={ui.home.title} descriptions={ui.home.description}>
  <div class="site-shell">
    <section class="hero" aria-labelledby="hero-title">
      <div>
        <h1 id="hero-title">
          <span data-lang="zh-CN">你好，我是<br />Steeefanie。</span>
          <span data-lang="zh-TW">你好，我是<br />Steeefanie。</span>
          <span data-lang="en">Hello, I’m<br />Steeefanie.</span>
        </h1>
        <p class="hero-intro"><LocalizedText value={ui.home.intro} /></p>
      </div>
      <div class="hero-aside">
        <div class="hero-note">
          <strong><LocalizedText value={ui.home.aboutTitle} /></strong>
          <p class="hero-about-text"><LocalizedText value={ui.home.aboutText} /></p>
        </div>
        <div class="hero-contact">
          <span class="hero-email">Contact: taichieh3@gmail.com</span>
          <a class="hero-github" href="https://github.com/Steeefanie" target="_blank" rel="noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.28-.36 6.72-1.61 6.72-7a5.4 5.4 0 0 0-1.42-3.73 5 5 0 0 0-.08-3S17.06.4 14 2.25a13.38 13.38 0 0 0-7 0C3.94.4 2.78.77 2.78.77a5 5 0 0 0-.08 3A5.4 5.4 0 0 0 1.28 7.5c0 5.42 3.44 6.67 6.72 7C7.31 15.1 6.69 16.25 7 17.5V22" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M7 18c-4.51 2-5-2-7-2" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="latest-heading">
      <div class="section-heading">
        <h2 id="latest-heading"><LocalizedText value={ui.home.latest} /></h2>
      </div>
      <ul class="content-list">
        {latest.map(({ section, group, base }) => (
          <LatestListItem
            section={section}
            href={`${base}${group.slug}/`}
            date={group.locales['zh-CN'].data.publishDate}
            content={Object.fromEntries(locales.map((locale) => [locale, {
              title: group.locales[locale].data.title,
              description: group.locales[locale].data.description,
              attribution: 'attribution' in group.locales[locale].data
                ? group.locales[locale].data.attribution
                : undefined,
            }])) as any}
          />
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
