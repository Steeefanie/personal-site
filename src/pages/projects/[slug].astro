---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProseLayout from '../../components/ProseLayout.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import { pairEntries } from '../../lib/content';
import { localeDateFormats, locales, text, type Localized } from '../../lib/i18n';

interface Props { entries: Localized<CollectionEntry<'projects'>> }

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return pairEntries(entries).map((group) => ({ params: { slug: group.slug }, props: { entries: group.locales } }));
}

const { entries } = Astro.props;
const { Content: ZhCNContent } = await render(entries['zh-CN']);
const { Content: ZhTWContent } = await render(entries['zh-TW']);
const { Content: EnContent } = await render(entries.en);
const contents = { 'zh-CN': ZhCNContent, 'zh-TW': ZhTWContent, en: EnContent };
const base = entries['zh-CN'].data;
const titles = Object.fromEntries(locales.map((locale) => [locale, `${entries[locale].data.title}${locale === 'en' ? ' | ' : '｜'}Steeefanie`])) as Localized<string>;
const descriptions = Object.fromEntries(locales.map((locale) => [locale, entries[locale].data.description])) as Localized<string>;
const dates = Object.fromEntries(locales.map((locale) => {
  const date = entries[locale].data.updatedDate ?? entries[locale].data.publishDate;
  const formatted = new Intl.DateTimeFormat(localeDateFormats[locale], { dateStyle: 'long' }).format(date);
  return [locale, locale === 'en' ? `Updated ${formatted}` : locale === 'zh-TW' ? `更新於 ${formatted}` : `更新于 ${formatted}`];
})) as Localized<string>;
---

<BaseLayout activeNav="projects" titles={titles} descriptions={descriptions}>
  <article>
    <header class="article-header">
      <div class="reading-shell">
        <a class="text-link" href="/projects/"><LocalizedText value={text('返回项目', '返回專案', 'Back to Projects')} /></a>
        <div class="article-title-row">
          <h1>{locales.map((locale) => <span data-lang={locale}>{entries[locale].data.title}</span>)}</h1>
          {base.repositoryUrl && (
            <a class="project-repository-link" href={base.repositoryUrl} target="_blank" rel="noreferrer" aria-labelledby="project-repository-label">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M12 .7a11.5 11.5 0 0 0-3.64 22.4c.58.1.79-.25.79-.56v-2.23c-3.22.7-3.9-1.37-3.9-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.78 1.2 1.78 1.2 1.04 1.77 2.72 1.26 3.38.96.1-.75.4-1.26.74-1.55-2.57-.29-5.28-1.29-5.28-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.16 1.18A11 11 0 0 1 12 6.13c.98 0 1.95.13 2.87.39 2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.4-2.71 5.38-5.29 5.67.42.36.79 1.07.79 2.16v3.25c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .7Z" />
              </svg>
              <span id="project-repository-label" class="sr-only"><LocalizedText value={text('在 GitHub 查看项目', '在 GitHub 查看專案', 'View project on GitHub')} /></span>
            </a>
          )}
        </div>
        <p class="article-deck">{locales.map((locale) => <span data-lang={locale}>{entries[locale].data.attribution && <span class="content-attribution">{entries[locale].data.attribution}</span>}{entries[locale].data.description}</span>)}</p>
        <div class="article-meta">
          <time datetime={(base.updatedDate ?? base.publishDate).toISOString()}>{locales.map((locale) => <span data-lang={locale}>{dates[locale]}</span>)}</time>
          <span class="tag-list">{base.stack.map((item) => <span class="tag">#{item}</span>)}</span>
        </div>
      </div>
    </header>
    <ProseLayout>
      {locales.map((locale) => {
        const Content = contents[locale];
        return <div data-lang={locale}><Content /></div>;
      })}
    </ProseLayout>
  </article>
</BaseLayout>
